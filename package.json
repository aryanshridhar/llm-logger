{
  "name": "llm-logger",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight LLM inference logging system (chatbot + SDK + ingestion + dashboard)",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./backend/**\" --filter \"./packages/**\" --filter \"./frontend\" build",
    "dev": "dotenv -e .env -- pnpm -r --parallel --filter \"./backend/apps/**\" --filter \"./frontend\" dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @llm-logger/db db:generate",
    "db:push": "pnpm --filter @llm-logger/db db:push",
    "db:migrate": "pnpm --filter @llm-logger/db db:migrate",
    "db:studio": "pnpm --filter @llm-logger/db db:studio",
    "setup": "bash scripts/setup.sh",
    "compose:up": "docker compose up -d",
    "setup:local": "docker compose up -d && pnpm install && pnpm db:generate && pnpm db:push",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "compose:rebuild": "docker compose up -d --build"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "dotenv-cli": "7.4.2",
    "typescript": "5.6.3"
  },
  "packageManager": "pnpm@9.12.3"
}
