# Copy to .env (see README). Run: pnpm setup

GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=mock
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o-mini

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_logger?schema=public

CHAT_API_PORT=3001
INGESTION_API_PORT=3002
CHAT_API_URL=http://localhost:3001
INGESTION_API_URL=http://localhost:3002

VITE_CHAT_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

AWS_REGION=ap-south-1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/033879516341/llm-inference-logs-dev

MAX_HISTORY_MESSAGES=10
SYSTEM_PROMPT=You are a helpful AI assistant. Be concise, accurate, and conversational.

LOG_LEVEL=info
NODE_ENV=development
